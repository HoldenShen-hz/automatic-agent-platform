# Automatic Agent System - Environment Configuration
# Copy this file to .env and fill in your values.
# This template is safe to commit only while values remain empty or non-secret placeholders.
# NEVER commit .env files or real credentials.
# Production secrets must come from the approved secret manager or deployment environment.

# ===================
# Required
# ===================

# Database path (default: ./data/sqlite/phase1a-demo.db)
AA_DB_PATH=./data/sqlite/phase1a-demo.db

# JWT secret for API authentication (REQUIRED in production).
# SECURITY WARNING: leaving this empty or using a shared demo value disables production readiness.
# Do not commit real values. Store production secrets in the configured secret manager.
# Generate a local placeholder with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate by publishing a new secret-manager version, restarting API servers after
# deployment, and retiring the previous version only after active tokens expire.
AA_API_JWT_SECRET=

# PostgreSQL password is required by docker-compose when PostgreSQL is enabled.
# Generate a local placeholder with:
# node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_PASSWORD=

# ===================
# LLM Provider Configuration
# (At least one required)
# ===================

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# MiniMax
MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://api.minimaxi.com/v1

# ===================
# Storage (PostgreSQL)
# ===================

# Storage driver: "sqlite" or "postgres"
AA_STORAGE_DRIVER=sqlite

# PostgreSQL connection string (required if AA_STORAGE_DRIVER=postgres)
# AA_STORAGE_POSTGRES_DSN=postgresql://user:password@host:5432/database

# Run both SQLite and PostgreSQL in dual mode for migration validation
# AA_STORAGE_POSTGRES_DUAL_RUN=false

# Path to shadow SQLite database for PostgreSQL migration comparison
# AA_STORAGE_POSTGRES_SHADOW_SQLITE_PATH=

# ===================
# Build & Deployment
# ===================

# Build commit SHA (auto-set by CI)
# AA_BUILD_COMMIT=

# Build timestamp (auto-set by CI)
# AA_BUILD_TIMESTAMP=

# Build profile (e.g., "dev", "production")
# AA_BUILD_PROFILE=

# Feature flags (comma-separated)
# AA_FEATURE_FLAGS=

# Enabled extensions (comma-separated)
# AA_ENABLED_EXTENSIONS=

# Preserve dist directory during build
# AA_PRESERVE_DIST=false

# ===================
# Logging
# ===================

# Log level: debug, info, warn, error
AA_LOG_LEVEL=info

# Structured log file sink
# AA_LOG_FILE_PATH=
# AA_LOG_FILE_MAX_BYTES=10485760
# AA_LOG_FILE_MAX_FILES=5

# Structured log transports
# AA_LOG_STDOUT=false
# AA_LOG_FLUENTD_HOST=
# AA_LOG_FLUENTD_PORT=24224
# AA_LOG_FLUENTD_TAG=automatic-agent
# AA_LOG_FLUENTD_RECONNECT_INTERVAL_MS=5000
# AA_LOG_FLUENTD_BUFFER_LIMIT=10000
# AA_LOG_DATADOG_API_KEY=
# AA_LOG_DATADOG_SITE=datadoghq.com
# AA_LOG_DATADOG_SERVICE=automatic-agent
# AA_LOG_DATADOG_SOURCE=automatic-agent
# AA_LOG_DATADOG_BATCH_SIZE=100
# AA_LOG_DATADOG_FLUSH_INTERVAL_MS=5000

# API server runtime features
# AA_API_ENABLE_WEBSOCKET=true

# API rate limiting is enabled by default. Set AA_API_RATE_LIMIT_DISABLED=1 only for
# local debugging; production should keep limits enabled and prefer Redis-backed state.
# AA_API_RATE_LIMIT_DISABLED=false
# AA_API_RATE_LIMIT_REDIS=
# AA_API_RATE_LIMIT_WINDOW_MS=1000
# AA_API_RATE_LIMIT_MAX_CALLS=100

# OpenAPI JSON requires API authentication by default. Set to 1 only for a
# deliberately public local/staging documentation endpoint.
# AA_OPENAPI_PUBLIC=0

# Model call distributed rate limiting
# AA_MODEL_CALL_RATE_LIMIT_MAX_CALLS=100
# AA_MODEL_CALL_RATE_LIMIT_WINDOW_MS=1000
# AA_MODEL_CALL_RATE_LIMIT_REDIS_HOST=
# AA_MODEL_CALL_RATE_LIMIT_REDIS_PORT=6379
# AA_MODEL_CALL_RATE_LIMIT_REDIS_PASSWORD=
# AA_MODEL_CALL_RATE_LIMIT_REDIS_DB=0
# AA_MODEL_CALL_RATE_LIMIT_REDIS_KEY_PREFIX=ratelimit:
# AA_MODEL_CALL_RATE_LIMIT_REDIS_TLS=false

# Model-call retry and fallback. Fallback models are comma-separated provider model ids.
# AA_MODEL_PROVIDER_FALLBACK_MODELS=
# AA_MODEL_CALL_RETRY_MAX_ATTEMPTS=2
# AA_MODEL_CALL_RETRY_BASE_DELAY_MS=100

# In-memory IAM stores are blocked in production unless explicitly opted in.
# AA_ALLOW_IN_MEMORY_SESSION_STORE=0
# AA_ALLOW_IN_MEMORY_SERVICE_IDENTITY_STORE=0

# ===================
