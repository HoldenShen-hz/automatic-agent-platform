{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": false,
    "checkJs": false,
    "composite": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "scripts/**/*.mjs",
    "scripts/**/*.ts",
    "*.config.js",
    "*.config.cjs",
    "*.config.mjs"
  ],
  "exclude": []
}
