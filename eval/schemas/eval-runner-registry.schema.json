{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aa://eval/eval-runner-registry.schema.json",
  "type": "object",
  "required": ["$schema", "runners"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "eval/schemas/eval-runner-registry.schema.json"
    },
    "runners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["runnerId", "runnerVersion", "implementationRef"],
        "properties": {
          "runnerId": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "runnerVersion": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "implementationRef": {
            "type": "string",
            "pattern": "^src/[A-Za-z0-9_./-]+\\.ts$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
