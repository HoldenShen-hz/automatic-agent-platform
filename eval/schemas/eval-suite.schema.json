{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aa://eval/eval-suite.schema.json",
  "type": "object",
  "required": [
    "$schema",
    "divisionId",
    "datasetCardRef",
    "runnerRegistryRef",
    "runner",
    "reportRef",
    "lastRefreshedAt",
    "metrics"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "eval/schemas/eval-suite.schema.json"
    },
    "divisionId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "datasetCardRef": {
      "type": "string",
      "pattern": "^eval/datasets/[a-z0-9-]+/dataset-card\\.json$"
    },
    "runnerRegistryRef": {
      "type": "string",
      "const": "eval/runner-registry.json"
    },
    "runner": {
      "type": "object",
      "required": ["runnerId", "runnerVersion", "implementationRef"],
      "properties": {
        "runnerId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "runnerVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "implementationRef": {
          "type": "string",
          "pattern": "^src/[A-Za-z0-9_./-]+\\.ts$"
        }
      },
      "additionalProperties": false
    },
    "reportRef": {
      "type": "string",
      "pattern": "^docs_zh/divisions/[a-z0-9-]+/leadership-evidence/eval-report\\.md$"
    },
    "lastRefreshedAt": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
