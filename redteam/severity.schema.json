{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aa://redteam/severity.schema.json",
  "type": "object",
  "required": ["caseId", "severity", "objective", "scope", "evidenceRefs"],
  "properties": {
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "evidenceRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
