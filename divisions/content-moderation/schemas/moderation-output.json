{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContentModerationOutput",
  "type": "object",
  "required": ["summary", "result", "status"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "pending_review"]
    },
    "contentId": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
