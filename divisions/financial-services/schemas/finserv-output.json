{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinancialServicesOutput",
  "type": "object",
  "required": ["summary", "result", "status"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "pending_approval", "rejected"]
    },
    "complianceFlags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "advicePacket": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
