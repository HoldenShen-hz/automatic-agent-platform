{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DataEngineeringOutput",
  "type": "object",
  "required": ["summary", "result", "status"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "pending_review"]
    },
    "datasetId": {
      "type": "string"
    },
    "lineage": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
