{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CustomerServiceOutput",
  "type": "object",
  "required": ["summary", "result", "status"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "escalated"]
    },
    "ticketId": {
      "type": "string"
    },
    "sentiment": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
