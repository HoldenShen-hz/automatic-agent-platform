{
  "productName": "Automatic Agent Platform UI Linux",
  "identifier": "com.automaticagent.ui.linux",
  "app": {
    "windows": [
      {
        "title": "Automatic Agent Platform UI",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ]
  },
  "security": {
    "csp": "default-src 'self'; img-src 'self' data:; font-src 'self'; media-src 'self'; worker-src 'self'; connect-src 'self'; style-src 'self'; script-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; report-uri /csp-report",
    "dangerousDisableAssetCspModification": false
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    },
    "shell": {
      "open": false
    },
    "notification": {
      "all": false
    },
    "os": {
      "all": false
    }
  }
}
