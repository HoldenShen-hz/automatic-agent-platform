{
  "productName": "Automatic Agent Platform UI Mac",
  "identifier": "com.automaticagent.ui.macos",
  "app": {
    "windows": [
      {
        "title": "Automatic Agent Platform UI",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "security": {
    "csp": "default-src 'self'; img-src 'self' data: https:; connect-src 'self' https://updates.automatic-agent.example https://telemetry.automatic-agent.example; style-src 'self'; script-src 'self'; frame-ancestors 'none'; base-uri 'self'; object-src 'none'",
    "dangerousDisableAssetCspModification": false
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://updates.automatic-agent.example/macos/{{target}}/{{current_version}}"
      ],
      "pubkey": "macos-demo-public-key"
    },
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "os": {
      "all": true
    }
  }
}
