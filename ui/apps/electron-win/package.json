{
  "name": "@aa/electron-win",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "dev": "electron .",
    "smoke": "node ./src/index.ts"
  },
  "devDependencies": {
    "electron": "^35.3.0",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "com.automaticagent.platform.ui.electronwin",
    "asar": true,
    "files": [
      "src/**/*",
      "index.html",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "Automatic Agent Platform",
      "verifyUpdateCodeSignature": true,
      "signAndEditExecutable": true
    }
  }
}
