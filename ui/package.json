{
  "name": "automatic-agent-platform-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/shared/*",
    "packages/features/*",
    "packages/ui-core",
    "packages/ui-mobile",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "build": "node ./scripts/run-task-with-stamp.mjs build npm run build:app",
    "build:app": "npm --workspace @aa/web run build",
    "typecheck": "node ./scripts/run-task-with-stamp.mjs typecheck tsc -p tsconfig.json --noEmit",
    "test": "node ./scripts/run-task-with-stamp.mjs test vitest run",
    "test:e2e": "node ./scripts/run-task-with-stamp.mjs test-e2e vitest run tests/apps/web-e2e-smoke.test.tsx tests/apps/web-route-catalog.test.tsx tests/apps/shells.test.ts",
    "test:cross-platform": "node ./scripts/run-task-with-stamp.mjs test-cross-platform vitest run tests/apps/shells.test.ts tests/shared/native-modules.test.ts tests/unit/ui/apps/tauri-shell-security.test.ts",
    "test:playwright": "playwright test",
    "test:visual": "playwright test tests/playwright/visual-regression.spec.ts",
    "test:a11y": "playwright test tests/a11y/web-accessibility.spec.ts",
    "test:coverage": "node ./scripts/run-task-with-stamp.mjs test-coverage vitest run --coverage",
    "test:watch": "vitest",
    "coverage:gate": "npm run test:coverage",
    "lint": "node ./scripts/run-task-with-stamp.mjs lint eslint \"packages/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" \"tools/**/*.{ts,mjs}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "bundle:analyze": "node ./scripts/bundle-analysis.mjs",
    "perf:budget": "node ./scripts/perf-budget.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run bundle:analyze && npm run perf:budget && npm audit --audit-level=high",
    "dev:web": "npm --workspace @aa/web run dev"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.16",
    "echarts": "^5.6.0",
    "intl-messageformat": "^10.7.16",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "reactflow": "^11.11.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@eslint/js": "^9.25.1",
    "@playwright/test": "^1.50.1",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.25.1",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "storybook": "^8.6.14",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^7.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.6"
  }
}
