{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json"],
      "outputs": ["dist/**/*.tsbuildinfo"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "eslint.config.js"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["typecheck"],
      "inputs": ["**/*.test.ts", "**/*.test.tsx", "vitest.config.ts"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
