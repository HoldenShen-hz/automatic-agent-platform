{
  "name": "automatic-agent-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/src/index.js",
    "./apps": "./dist/src/apps/index.js",
    "./domains": "./dist/src/domains/index.js",
    "./interaction": "./dist/src/interaction/index.js",
    "./ops-maturity": "./dist/src/ops-maturity/index.js",
    "./org-governance": "./dist/src/org-governance/index.js",
    "./platform": "./dist/src/platform/index.js",
    "./platform/orchestration": "./dist/src/platform/orchestration/index.js",
    "./platform/orchestration/improve-rollout": "./dist/src/platform/orchestration/improve-rollout/index.js",
    "./platform/orchestration/learn": "./dist/src/platform/orchestration/learn/index.js",
    "./platform/stability": "./dist/src/platform/stability/index.js",
    "./plugins": "./dist/src/plugins/index.js",
    "./scale-ecosystem": "./dist/src/scale-ecosystem/index.js",
    "./scale-ecosystem/runtime-services": "./dist/src/scale-ecosystem/runtime-services/index.js",
    "./sdk": "./dist/src/sdk/index.js",
    "./package.json": "./package.json"
  },
  "description": "Enterprise automatic agent platform baseline with seven-layer architecture docs, durable runtime, AI operations primitives, and operational maturity tooling.",
  "scripts": {
    "build": "node --enable-source-maps scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "build:test": "AA_PRESERVE_DIST=1 npm run build && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ci:baseline": "npm run typecheck && npm test && AA_VALIDATION_ITERATIONS=2 npm run validate:stable",
    "start": "node --enable-source-maps dist/src/index.js",
    "doctor": "npm run build && node --enable-source-maps dist/src/sdk/cli/doctor.js",
    "dlq": "npm run build && node --enable-source-maps dist/src/sdk/cli/dlq-manager.js",
    "dlq:list": "npm run dlq -- -a list",
    "dlq:count": "npm run dlq -- -a count",
    "authoritative-storage": "npm run build && node --enable-source-maps dist/src/sdk/cli/authoritative-storage-admin.js",
    "dispatch-execution": "npm run build && node --enable-source-maps dist/src/sdk/cli/dispatch-execution.js",
    "dispatch-reconcile": "npm run build && node --enable-source-maps dist/src/sdk/cli/dispatch-reconcile.js",
    "drain-events": "npm run build && node --enable-source-maps dist/src/sdk/cli/drain-events.js",
    "diagnostics": "npm run build && node --enable-source-maps dist/src/sdk/cli/diagnostics.js",
    "billing": "npm run build && node --enable-source-maps dist/src/sdk/cli/billing.js",
    "enterprise": "npm run build && node --enable-source-maps dist/src/sdk/cli/enterprise-capability.js",
    "enterprise-governance": "npm run build && node --enable-source-maps dist/src/sdk/cli/enterprise-governance.js",
    "acceptance-readiness": "npm run build && node --enable-source-maps dist/src/sdk/cli/acceptance-readiness.js",
    "marketplace": "npm run build && node --enable-source-maps dist/src/sdk/cli/marketplace.js",
    "api": "npm run build && node --enable-source-maps dist/src/sdk/cli/api-server.js",
    "channel-gateway": "npm run build && node --enable-source-maps dist/src/sdk/cli/channel-gateway.js",
    "control-plane-balancer": "npm run build && node --enable-source-maps dist/src/sdk/cli/control-plane-balancer.js",
    "evolution": "npm run build && node --enable-source-maps dist/src/sdk/cli/evolution.js",
    "gateway-targets": "npm run build && node --enable-source-maps dist/src/sdk/cli/gateway-targets.js",
    "skill-creator": "npm run build && node --enable-source-maps dist/src/sdk/cli/skill-creator.js",
    "inspect": "npm run build && node --enable-source-maps dist/src/sdk/cli/inspect.js",
    "knowledge-semantic-readiness": "npm run build && node --enable-source-maps dist/src/sdk/cli/knowledge-semantic-readiness.js",
    "memory": "npm run build && node --enable-source-maps dist/src/sdk/cli/memory.js",
    "model-routing": "npm run build && node --enable-source-maps dist/src/sdk/cli/model-routing.js",
    "shadow-snapshot": "npm run build && node --enable-source-maps dist/src/sdk/cli/shadow-snapshot.js",
    "perception": "npm run build && node --enable-source-maps dist/src/sdk/cli/perception.js",
    "pmf": "npm run build && node --enable-source-maps dist/src/sdk/cli/pmf.js",
    "platform-operator": "npm run build && node --enable-source-maps dist/src/sdk/cli/platform-operator.js",
    "lease-handover": "npm run build && node --enable-source-maps dist/src/sdk/cli/lease-handover.js",
    "orphan-cleanup": "npm run build && node --enable-source-maps dist/src/sdk/cli/orphan-cleanup.js",
    "ops-governance": "npm run build && node --enable-source-maps dist/src/sdk/cli/ops-governance.js",
    "ops-program": "npm run build && node --enable-source-maps dist/src/sdk/cli/ops-program.js",
    "release-pipeline": "npm run build && node --enable-source-maps dist/src/sdk/cli/release-pipeline.js",
    "environment-deployment": "npm run build && node --enable-source-maps dist/src/sdk/cli/environment-deployment.js",
    "deployment-execution": "npm run build && node --enable-source-maps dist/src/sdk/cli/deployment-execution.js",
    "secret-management": "npm run build && node --enable-source-maps dist/src/sdk/cli/secret-management.js",
    "profile-home": "npm run build && node --enable-source-maps dist/src/sdk/cli/profile-home.js",
    "ha-program": "npm run build && node --enable-source-maps dist/src/sdk/cli/ha-program.js",
    "compliance-program": "npm run build && node --enable-source-maps dist/src/sdk/cli/compliance-program.js",
    "task-board": "npm run build && node --enable-source-maps dist/src/sdk/cli/task-board.js",
    "tenant-platform": "npm run build && node --enable-source-maps dist/src/sdk/cli/tenant-platform.js",
    "data-plane": "npm run build && node --enable-source-maps dist/src/sdk/cli/data-plane.js",
    "replay-events": "npm run build && node --enable-source-maps dist/src/sdk/cli/replay-events.js",
    "replay-recovery": "npm run build && node --enable-source-maps dist/src/sdk/cli/replay-recovery.js",
    "repair": "npm run build && node --enable-source-maps dist/src/sdk/cli/repair.js",
    "takeover": "npm run build && node --enable-source-maps dist/src/sdk/cli/takeover.js",
    "chaos:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-chaos.js",
    "concurrency:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-concurrency.js",
    "lease:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-lease.js",
    "maintenance:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-maintenance.js",
    "db-queue-disconnect:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-db-queue-disconnect.js",
    "db-writability:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-db-writability.js",
    "migration:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-migration-compatibility.js",
    "queue:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-queue-delivery.js",
    "gray:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-gray.js",
    "prompt-injection:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-prompt-injection.js",
    "rollback:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-rollback.js",
    "recovery-drill:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-recovery-drill.js",
    "dispatch:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-dispatch.js",
    "dispatch-reconcile:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-dispatch-reconcile.js",
    "worker-handshake": "npm run build && node --enable-source-maps dist/src/sdk/cli/worker-handshake.js",
    "worker-handshake:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-worker-handshake.js",
    "worker-register": "npm run build && node --enable-source-maps dist/src/sdk/cli/worker-register.js",
    "worker-writeback": "npm run build && node --enable-source-maps dist/src/sdk/cli/worker-writeback.js",
    "worker-writeback:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-worker-writeback.js",
    "replay:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-replay.js",
    "restore:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-restore.js",
    "upgrade:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-upgrade.js",
    "evidence:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-evidence.js",
    "campaign:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-campaign.js",
    "sequence:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-sequence.js",
    "gate:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-gate.js",
    "package:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-package.js",
    "validate:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-validate.js",
    "soak:stable": "npm run build && node --enable-source-maps dist/src/sdk/cli/stable-soak.js",
    "demo": "npm run build && node --enable-source-maps dist/src/index.js",
    "demo:phase1b": "npm run build && node --enable-source-maps dist/src/sdk/cli/phase1b-demo.js",
    "lint": "eslint src/",
    "test:raw": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 c8 node --test --test-concurrency=12 \"dist/tests/unit/**/*.test.js\" \"dist/tests/integration/**/*.test.js\" \"dist/tests/golden/**/*.test.js\" \"dist/tests/e2e/**/*.test.js\" && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 c8 --no-clean node --test --test-concurrency=1 \"dist/tests/performance/**/*.test.js\"",
    "coverage:report": "node scripts/ci/generate-coverage-report.mjs",
    "coverage:gate": "npm run coverage:report && node scripts/ci/check-coverage-baseline.mjs",
    "coverage:baseline:update": "npm run coverage:report && node scripts/ci/update-coverage-baseline.mjs",
    "changelog:check": "node scripts/ci/check-changelog.mjs",
    "test": "npm run test:raw && npm run coverage:gate",
    "test:golden": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 node --test --test-concurrency=12 \"dist/tests/golden/**/*.test.js\"",
    "test:unit": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 node --test --test-concurrency=12 \"dist/tests/unit/**/*.test.js\"",
    "test:integration": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 node --test --test-concurrency=12 \"dist/tests/integration/**/*.test.js\"",
    "test:pg-integration": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 node --test --test-concurrency=1 \"dist/tests/integration/storage/**/*.test.js\"",
    "test:secret-providers": "AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 npm run build:test && AA_RUNNING_TESTS=1 AA_PRESERVE_DIST=1 node --test --test-concurrency=1 \"dist/tests/integration/security/secret-provider-integration.test.js\"",
    "test:performance": "node --test --test-concurrency=1 \"dist/tests/performance/**/*.test.js\"",
    "test:mutation": "stryker run",
    "stryker": "stryker run",
    "migrate:status": "npm run build && AA_AUTHORITATIVE_STORAGE_ACTION=status node --enable-source-maps dist/src/sdk/cli/authoritative-storage-admin.js",
    "migrate:up": "npm run build && AA_AUTHORITATIVE_STORAGE_ACTION=up node --enable-source-maps dist/src/sdk/cli/authoritative-storage-admin.js",
    "migrate:down": "npm run build && AA_AUTHORITATIVE_STORAGE_ACTION=down node --enable-source-maps dist/src/sdk/cli/authoritative-storage-admin.js",
    "migrate:sqlite-to-pg": "npm run build && node --enable-source-maps dist/src/sdk/cli/migrate-sqlite-to-pg.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "typescript": "^5.8.3",
    "ws": "^8.18.0",
    "xml-crypto": "^2.1.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.0",
    "@types/xml-crypto": "^1.4.6",
    "c8": "^11.0.0",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.31.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
