# Automatic Agent Platform environment template
# Copy to .env for local development only. Keep production secrets in the
# deployment environment or the approved secret manager.
#
# For the long-tail environment catalogue, see:
# - docs_zh/reference/environment-configuration.md
# - docs_en/reference/environment-configuration.md

# ===================
# Required for local runtime
# ===================

AA_DB_PATH=./data/sqlite/automatic-agent-demo.db
AA_STORAGE_DRIVER=sqlite
AA_LOG_LEVEL=info

# Generate local placeholder values; do not commit real credentials.
AA_API_JWT_SECRET=
POSTGRES_PASSWORD=change-me-local-only

# At least one provider key is required when model-backed flows are exercised.
ANTHROPIC_API_KEY=
AA_OPENAI_API_KEY=
AA_MINIMAX_API_KEY=

# ===================
# Common local runtime options
# ===================

# AA_STORAGE_POSTGRES_DSN=postgresql://user:password@host:5432/database
# AA_PG_DSN=postgresql://user:password@host:5432/database
# AA_BUILD_COMMIT=
# AA_BUILD_TIMESTAMP=
# AA_BUILD_PROFILE=dev
# AA_FEATURE_FLAGS=
# AA_ENABLED_EXTENSIONS=
# AA_PRESERVE_DIST=false

# API and auth
# AA_API_ENABLE_WEBSOCKET=true
# AA_API_RATE_LIMIT_DISABLED=false
# AA_API_RATE_LIMIT_REDIS=
# AA_OPENAPI_PUBLIC=0

# Logging and observability
# AA_LOG_FILE_PATH=
# AA_LOG_FILE_MAX_BYTES=10485760
# AA_LOG_FILE_MAX_FILES=5
# AA_OTEL_ENABLED=false
# AA_OTEL_SERVICE_NAME=automatic-agent
# AA_OTEL_ENDPOINT=

# Redis-backed rate limiting
# AA_MODEL_CALL_RATE_LIMIT_MAX_CALLS=100
# AA_MODEL_CALL_RATE_LIMIT_WINDOW_MS=1000
# AA_MODEL_CALL_RATE_LIMIT_REDIS_HOST=
# AA_MODEL_CALL_RATE_LIMIT_REDIS_PORT=6379
# AA_MODEL_CALL_RATE_LIMIT_REDIS_PASSWORD=
# AA_MODEL_CALL_RATE_LIMIT_REDIS_DB=0

# ===================
# Stable / validation outputs
# ===================

# Set only the directories you actively use.
# AA_STABLE_GATE_EVIDENCE_ROOT=
# AA_STABLE_PACKAGE_OUTPUT_DIR=
# AA_STABLE_VALIDATION_OUTPUT_DIR=
# AA_STABLE_CHAOS_OUTPUT_DIR=
# AA_STABLE_RECOVERY_DRILL_OUTPUT_DIR=
# AA_STABLE_WORKER_HANDSHAKE_OUTPUT_DIR=
# AA_STABLE_WORKER_WRITEBACK_OUTPUT_DIR=
# AA_VALIDATION_ITERATIONS=10

# ===================
# Execution context and debugging
# ===================

# AA_EXECUTION_ID=
# AA_TASK_ID=
# AA_SESSION_ID=
# AA_AGENT_ID=
# AA_OCCURRED_AT=
# AA_REASON_CODE=
# AA_STATUS=

# ===================
# Model routing
# ===================

# AA_CONFIG_ROOT=./config
# AA_MODEL_ROUTE_CLASS=balanced
# AA_MODEL_ROUTE_RISK_LEVEL=medium
# AA_MODEL_ROUTE_PREFERRED_PROFILE=
# AA_MODEL_ROUTE_PINNED_PROFILE=
# AA_MODEL_ROUTE_REQUIRED_CAPABILITIES=

# ===================
# Safety notes
# ===================

# 1. This file intentionally keeps secret values empty.
# 2. Add only the variables you need locally; prefer explicit minimal config.
# 3. Do not use this template as a credential inventory.
