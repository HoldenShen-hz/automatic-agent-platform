/**
 * Performance Test: Provider Load and Stress Testing
 *
 * Tests provider behavior under sustained load and stress conditions.
 * Verifies circuit breaker behavior and graceful degradation.
 */

import assert from "node:assert/strict";
import test from "node:test";
import { join } from "node:path";

import { SqliteDatabase } from "../../src/core/storage/sqlite/sqlite-database.js";
import { AuthoritativeTaskStore } from "../../src/core/storage/authoritative-task-store.js";
import { cleanupPath, createTempWorkspace } from "../helpers/fs.js";
import { newId, nowIso } from "../../src/core/types/ids.js";
import { IntakeRouter } from "../../src/core/orchestration/intake-router.js";

test("performance: IntakeRouter.route() handles sustained high throughput", () => {
  const workspace = createTempWorkspace("perf-intake-throughput-");
  const latencies: number[] = [];

  try {
    const router = new IntakeRouter();
    const iterations = 1000;

    const requests = [
      { title: "Analyze the quarterly sales report", request: "Please analyze the quarterly sales data and provide insights" },
      { title: "Fix bug in login", request: "The login button doesn't work when clicking" },
      { title: "Create report", request: "Generate a summary report for the meeting" },
      { title: "Review code", request: "Please review the pull request for any issues" },
      { title: "Plan project", request: "Help me plan the new feature implementation" },
    ];

    for (let i = 0; i < iterations; i++) {
      const req = requests[i % requests.length]!;
      const start = performance.now();
      router.route({ title: req.title, request: req.request });
      const end = performance.now();
      latencies.push(end - start);
    }

    latencies.sort((a, b) => a - b);
    const p50Latency = latencies[Math.floor(iterations * 0.5)!]!;
    const p95Latency = latencies[Math.floor(iterations * 0.95)!]!;
    const p99Latency = latencies[Math.floor(iterations * 0.99)!]!;

    assert.ok(
      p50Latency < 5,
      `IntakeRouter.route() P50 latency ${p50Latency.toFixed(3)}ms exceeds 5ms target under load`,
    );
    assert.ok(
      p95Latency < 10,
      `IntakeRouter.route() P95 latency ${p95Latency.toFixed(3)}ms exceeds 10ms target under load`,
    );
    assert.ok(
      p99Latency < 20,
      `IntakeRouter.route() P99 latency ${p99Latency.toFixed(3)}ms exceeds 20ms target under load`,
    );
  } finally {
    cleanupPath(workspace);
  }
});

test("performance: IntakeRouter.route() meets P95 < 5ms baseline under moderate load", () => {
  const workspace = createTempWorkspace("perf-intake-moderate-");
  const latencies: number[] = [];

  try {
    const router = new IntakeRouter();
    const iterations = 500;

    for (let i = 0; i < iterations; i++) {
      const start = performance.now();
      router.route({
        title: "Query analysis request",
        request: "Analyze the data trends for the past month",
      });
      const end = performance.now();
      latencies.push(end - start);
    }

    latencies.sort((a, b) => a - b);
    const p95Latency = latencies[Math.floor(iterations * 0.95)!]!;

    assert.ok(
      p95Latency < 5,
      `IntakeRouter.route() P95 latency ${p95Latency.toFixed(3)}ms exceeds 5ms baseline`,
    );
  } finally {
    cleanupPath(workspace);
  }
});

test("stress: IntakeRouter handles burst of varied requests", () => {
  const workspace = createTempWorkspace("perf-intake-burst-");
  const results: Array<{ workflowId: string; requiresOrchestration: boolean }> = [];

  try {
    const router = new IntakeRouter();

    const burstRequests = [
      { title: "Write code", request: "Implement a new feature" },
      { title: "Analyze data", request: "Review the metrics" },
      { title: "Create report", request: "Generate weekly summary" },
      { title: "Fix issue", request: "Debug the problem" },
      { title: "Plan task", request: "Create an implementation plan" },
      { title: "Review PR", request: "Check the changes" },
      { title: "Update docs", request: "Document the API" },
      { title: "Test system", request: "Run the test suite" },
    ];

    for (let i = 0; i < 200; i++) {
      const req = burstRequests[i % burstRequests.length]!;
      const result = router.route({ title: req.title, request: req.request });
      results.push({ workflowId: result.workflowId, requiresOrchestration: result.requiresOrchestration });
    }

    assert.ok(results.length === 200, "All burst requests should complete");
    const orchestratedCount = results.filter((r) => r.requiresOrchestration).length;
    assert.ok(orchestratedCount > 0, "Some requests should require orchestration");
  } finally {
    cleanupPath(workspace);
  }
});

test("stress: IntakeRouter remains stable under extreme request rate", () => {
  const workspace = createTempWorkspace("perf-intake-extreme-");
  const errorCount = 0;

  try {
    const router = new IntakeRouter();
    const iterations = 500;

    for (let i = 0; i < iterations; i++) {
      try {
        router.route({
          title: `Request ${i}`,
          request: "Process this task with all the necessary analysis and planning",
        });
      } catch {
        assert.fail("IntakeRouter should not throw under stress");
      }
    }
  } finally {
    cleanupPath(workspace);
  }
});

test("load: IntakeRouter routes correctly with many divisions", () => {
  const workspace = createTempWorkspace("perf-intake-divisions-");

  try {
    const router = new IntakeRouter();
    const iterations = 300;

    for (let i = 0; i < iterations; i++) {
      const result = router.route({
        title: "Multi-division request",
        request: "This needs to be routed to the appropriate division based on content",
      });
      assert.ok(result.divisionId, "Should have a divisionId");
      assert.ok(result.workflowId, "Should have a workflowId");
    }
  } finally {
    cleanupPath(workspace);
  }
});
