/**
 * Performance Test: Memory Retrieval Latency
 *
 * Establishes performance baselines for memory service operations.
 */

import assert from "node:assert/strict";
import test from "node:test";
import { join } from "node:path";

import { SqliteDatabase } from "../../src/core/storage/sqlite/sqlite-database.js";
import { MemoryService } from "../../src/core/memory/memory-service.js";
import { cleanupPath, createTempWorkspace } from "../helpers/fs.js";
import { newId, nowIso } from "../../src/core/types/ids.js";
import { AuthoritativeTaskStore } from "../../src/core/storage/authoritative-task-store.js";

test("performance: MemoryService.recall() meets P95 < 50ms baseline", () => {
  const workspace = createTempWorkspace("perf-memory-");

  try {
    const dbPath = join(workspace, "perf-memory.db");
    const db = new SqliteDatabase(dbPath);
    db.migrate();
    const store = new AuthoritativeTaskStore(db);
    const memoryService = new MemoryService(store);

    const now = nowIso();
    const sessionId = newId("sess");
    const taskId = newId("task");

    // Create session and memories using the store directly
    db.transaction(() => {
      store.insertTask({
        id: taskId,
        parentId: null,
        rootId: taskId,
        divisionId: "general_ops",
        title: "Memory perf test",
        status: "done",
        source: "user",
        priority: "normal",
        inputJson: "{}",
        normalizedInputJson: "{}",
        outputJson: null,
        estimatedCostUsd: 0,
        actualCostUsd: 0,
        errorCode: null,
        createdAt: now,
        updatedAt: now,
        completedAt: now,
      });

      // Insert multiple memory records
      for (let i = 0; i < 50; i++) {
        memoryService.remember({
          taskId,
          sessionId,
          scope: "test-scope",
          content: `Memory content ${i}: This is test memory data for recall performance testing.`,
          classification: "test",
          qualityScore: 0.8,
        });
      }
    });

    const latencies: number[] = [];
    const iterations = 100;

    for (let i = 0; i < iterations; i++) {
      const start = performance.now();
      // Recall memories by sessionId
      memoryService.recall({ sessionId, limit: 10 });
      const end = performance.now();
      latencies.push(end - start);
    }

    // Calculate P95
    latencies.sort((a, b) => a - b);
    const p95Index = Math.floor(iterations * 0.95);
    const p95Latency = latencies[p95Index]!;

    // P95 should be < 50ms for recall
    assert.ok(
      p95Latency < 50,
      `MemoryService.recall() P95 latency ${p95Latency.toFixed(3)}ms exceeds 50ms baseline`,
    );

    db.close();
  } finally {
    cleanupPath(workspace);
  }
});
