{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "automatic-agent-platform": ["src/index.ts"],
      "automatic-agent-platform/apps": ["src/apps/index.ts"],
      "automatic-agent-platform/domains": ["src/domains/index.ts"],
      "automatic-agent-platform/interaction": ["src/interaction/index.ts"],
      "automatic-agent-platform/ops-maturity": ["src/ops-maturity/index.ts"],
      "automatic-agent-platform/org-governance": ["src/org-governance/index.ts"],
      "automatic-agent-platform/platform": ["src/platform/index.ts"],
      "automatic-agent-platform/platform/five-plane-orchestration": ["src/platform/five-plane-orchestration/index.ts"],
      "automatic-agent-platform/platform/five-plane-orchestration/improve-rollout": ["src/platform/five-plane-orchestration/improve-rollout/index.ts"],
      "automatic-agent-platform/platform/five-plane-orchestration/learn": ["src/platform/five-plane-orchestration/learn/index.ts"],
      "automatic-agent-platform/platform/stability": ["src/platform/stability/index.ts"],
      "automatic-agent-platform/plugins": ["src/plugins/index.ts"],
      "automatic-agent-platform/testing": ["src/testing/index.ts"],
      "automatic-agent-platform/benchmarks": ["src/benchmarks/index.ts"],
      "automatic-agent-platform/scale-ecosystem": ["src/scale-ecosystem/index.ts"],
      "automatic-agent-platform/scale-ecosystem/billing": ["src/scale-ecosystem/billing/index.ts"],
      "automatic-agent-platform/scale-ecosystem/enterprise": ["src/scale-ecosystem/enterprise/index.ts"],
      "automatic-agent-platform/scale-ecosystem/intelligence": ["src/scale-ecosystem/intelligence/index.ts"],
      "automatic-agent-platform/scale-ecosystem/operations": ["src/scale-ecosystem/operations/index.ts"],
      "automatic-agent-platform/scale-ecosystem/runtime-services": ["src/scale-ecosystem/runtime-services/index.ts"],
      "automatic-agent-platform/scale-ecosystem/tenant-platform": ["src/scale-ecosystem/tenant-platform/index.ts"],
      "automatic-agent-platform/sdk": ["src/sdk/index.ts"],
      "automatic-agent-platform/sdk/admin-sdk": ["src/sdk/admin-sdk/index.ts"],
      "automatic-agent-platform/sdk/cli": ["src/sdk/cli/index.ts"],
      "automatic-agent-platform/sdk/client-sdk": ["src/sdk/client-sdk/index.ts"],
      "automatic-agent-platform/sdk/harness-sdk": ["src/sdk/harness-sdk/index.ts"],
      "automatic-agent-platform/sdk/pack-sdk": ["src/sdk/pack-sdk/index.ts"],
      "automatic-agent-platform/sdk/plugin-sdk": ["src/sdk/plugin-sdk/index.ts"],
      "automatic-agent-platform/sdk/workbench": ["src/sdk/workbench/index.ts"],
      "automatic-agent-platform/cli": ["src/sdk/cli/index.ts"]
    },
    "outDir": "dist",
    "incremental": true,
    "tsBuildInfoFile": ".cache/tsconfig.tsbuildinfo",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "helpers/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
