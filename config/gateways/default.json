{
  "defaultGateway": "cli",
  "sseEnabled": true,
  "rateLimit": {
    "enabled": true,
    "maxRequestsPerMinute": 1200,
    "burstSize": 120
  },
  "cors": {
    "enabled": true,
    "allowOrigins": ["http://localhost:3000", "http://127.0.0.1:3000"],
    "allowMethods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
    "allowHeaders": ["authorization", "content-type", "x-sdk-version", "x-contract-version", "x-platform-min-version"]
  },
  "auth": {
    "required": true,
    "supportedSchemes": ["bearer", "session_cookie"]
  },
  "requestLimits": {
    "maxRequestBodyBytes": 1048576,
    "maxBatchItems": 100
  },
  "websocket": {
    "enabled": true,
    "path": "/ws/v1/stream",
    "maxConnections": 10000,
    "heartbeatIntervalMs": 30000,
    "maxMessageSizeBytes": 65536,
    "backpressureThresholdBytes": 1048576,
    "authViaSubprotocol": true
  }
}
