{
  "$schema": "../../../src/platform/contracts/types/schemas/config-schema.ts",
  "factorWeights": {
    "stepTypeRisk": 3,
    "targetSystemRisk": 4,
    "dataClassRisk": 3,
    "blastRadius": 2,
    "priorFailureRate": 2,
    "confidence": 1
  },
  "stepTypeRiskValues": {
    "read": 1,
    "write": 3,
    "delete": 5,
    "external_call": 4
  },
  "targetSystemRiskValues": {
    "internal": 1,
    "staging": 2,
    "production": 5
  },
  "dataClassRiskValues": {
    "public": 1,
    "internal": 2,
    "confidential": 4,
    "restricted": 5
  },
  "blastRadiusValues": {
    "single_task": 1,
    "workflow": 2,
    "tenant": 3,
    "platform": 5
  },
  "priorFailureRateThresholds": {
    "low": { "maxPercent": 10, "value": 1 },
    "medium": { "maxPercent": 30, "value": 2 },
    "high": { "maxPercent": 50, "value": 3 },
    "critical": { "maxPercent": 100, "value": 5 }
  },
  "confidenceValues": {
    "high": 1,
    "medium": 3,
    "low": 5
  },
  "riskLevelThresholds": {
    "low": 0.25,
    "medium": 0.5,
    "high": 0.75,
    "critical": 1.0
  },
  "riskLevelActions": {
    "low": {
      "autoExecute": true,
      "logLevel": "info",
      "requiresApproval": false,
      "sideEffect": "normal",
      "evidenceLevel": "basic"
    },
    "medium": {
      "autoExecute": true,
      "logLevel": "warn",
      "requiresApproval": false,
      "sideEffect": "normal_with_validation",
      "evidenceLevel": "enhanced"
    },
    "high": {
      "autoExecute": false,
      "logLevel": "error",
      "requiresApproval": true,
      "sideEffect": "restricted",
      "evidenceLevel": "full"
    },
    "critical": {
      "autoExecute": false,
      "logLevel": "critical",
      "requiresApproval": true,
      "approvalType": "break_glass",
      "sideEffect": "prohibited",
      "evidenceLevel": "legal"
    }
  }
}
