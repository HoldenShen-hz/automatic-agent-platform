{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Canonical risk configuration aligned with §28 Event Registry and DLQ model",
  "riskCategories": [
    "operational",
    "financial",
    "compliance",
    "reputational",
    "safety",
    "strategic"
  ],
  "factorWeights": {
    "targetSystemRisk": 4,
    "dataClassRisk": 3,
    "blastRadius": 2,
    "priorFailureRate": 2,
    "confidence": 1
  },
  "systemRiskValues": {
    "internal": 1,
    "staging": 2,
    "production": 5
  },
  "dataClassRiskValues": {
    "public": 1,
    "internal": 2,
    "confidential": 4,
    "restricted": 5
  },
  "blastRadiusValues": {
    "single_task": 1,
    "workflow": 2,
    "tenant": 3,
    "platform": 5
  },
  "priorFailureRateThresholds": {
    "low": { "maxPercent": 10, "value": 1 },
    "medium": { "maxPercent": 30, "value": 2 },
    "high": { "maxPercent": 50, "value": 3 },
    "critical": { "maxPercent": 100, "value": 5 }
  },
  "confidenceValues": {
    "high": 1,
    "medium": 3,
    "low": 5
  },
  "riskLevelThresholds": {
    "low": 0.25,
    "medium": 0.5,
    "high": 0.75,
    "critical": 1.0
  },
  "riskLevelActions": {
    "low": {
      "autoExecute": true,
      "logLevel": "info",
      "requiresApproval": false,
      "sideEffect": "normal",
      "evidenceLevel": "basic"
    },
    "medium": {
      "autoExecute": true,
      "logLevel": "warn",
      "requiresApproval": false,
      "sideEffect": "normal_with_validation",
      "evidenceLevel": "enhanced"
    },
    "high": {
      "autoExecute": false,
      "logLevel": "error",
      "requiresApproval": true,
      "approvalType": "standard",
      "sideEffect": "restricted",
      "evidenceLevel": "full"
    },
    "critical": {
      "autoExecute": false,
      "logLevel": "critical",
      "requiresApproval": true,
      "approvalType": "break_glass",
      "sideEffect": "prohibited",
      "evidenceLevel": "legal"
    }
  },
  "eventRegistry": {
    "namespace": "platform.risk",
    "tier1Events": [
      "risk.assessment.completed",
      "risk.level.changed",
      "risk.breach.detected"
    ],
    "dlqModel": {
      "enabled": true,
      "maxRetries": 3,
      "retryBackoffMs": 5000,
      "deadLetterActions": [
        "alert",
        "block_execution",
        "require_approval"
      ]
    }
  },
  "autonomyRiskCaps": {
    "critical": "manual",
    "high": "semi_auto",
    "medium": "supervised",
    "low": "full_auto"
  },
  "domainRiskDefaults": {
    "healthcare": {
      "riskLevel": "critical",
      "maxAutonomy": "manual",
      "advisoryOnly": true,
      "humanAccountable": true,
      "deterministicHotPathOnly": true
    },
    "quant_trading": {
      "riskLevel": "high",
      "maxAutonomy": "supervised",
      "advisoryOnly": false,
      "humanAccountable": true,
      "deterministicHotPathOnly": true
    },
    "financial_services": {
      "riskLevel": "high",
      "maxAutonomy": "supervised",
      "advisoryOnly": false,
      "humanAccountable": true,
      "deterministicHotPathOnly": false
    },
    "legal": {
      "riskLevel": "high",
      "maxAutonomy": "supervised",
      "advisoryOnly": false,
      "humanAccountable": true,
      "deterministicHotPathOnly": false
    }
  }
}