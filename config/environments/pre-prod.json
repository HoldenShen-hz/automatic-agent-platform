{
  "environment": "pre-prod",
  "registry": "ghcr.io/automatic-agent",
  "imageRepository": "automatic-agent-platform",
  "deploymentNamespace": "automatic-agent-preprod",
  "configPath": "config/runtime/default.json",
  "configBundleRef": "config-bundle://runtime/pre-prod",
  "registryCredentialRef": "secret://system/registry/ghcr/pre-prod",
  "deploymentCredentialRef": "secret://system/deploy/kubeconfig/pre-prod",
  "deployWorkflowPath": ".github/workflows/deploy-environment.yml",
  "publishWorkflowPath": ".github/workflows/publish-image.yml",
  "clusterName": "preprod-cluster",
  "allowedRolloutStrategies": ["canary", "blue_green"]
}
