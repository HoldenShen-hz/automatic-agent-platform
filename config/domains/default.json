{
  "domains": [
    {
      "domainId": "coding",
      "name": "Coding",
      "description": "Coding workflows, tools, and plugin bindings.",
      "version": "1.0.0",
      "riskSpec": {
        "advisoryOnly": false,
        "humanAccountable": false,
        "deterministicHotPathOnly": false
      },
      "workflows": [
        {
          "workflowId": "coding-default",
          "name": "Coding Default Workflow",
          "triggerConditions": {},
          "planGraph": {
            "graphId": "graph:coding:default",
            "nodes": [
              {
                "nodeId": "node:coding:analyze",
                "nodeType": "llm",
                "inputRefs": ["task:${taskId}"],
                "outputSchemaRef": "schema:coding.analyze",
                "riskClass": "low",
                "budgetIntent": {
                  "amount": 0.1,
                  "currency": "USD",
                  "resourceKinds": ["token"]
                },
                "sideEffectProfile": {
                  "mayCommitExternalEffect": false,
                  "reversible": true
                },
                "retryPolicyRef": "retry:coding.default",
                "timeoutMs": 60000
              }
            ],
            "edges": [],
            "entryNodeIds": ["node:coding:analyze"],
            "terminalNodeIds": ["node:coding:analyze"],
            "joinStrategy": "all",
            "graphHash": "coding-default-workflow-hash"
          }
        }
      ],
      "toolBundles": [
        {
          "bundleId": "coding-default",
          "tools": [
            {
              "toolName": "repo_map",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "patch_apply",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "test_runner",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "static_analysis",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "file_read",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "file_write",
              "enabled": true,
              "configOverrides": {}
            },
            {
              "toolName": "shell_exec",
              "enabled": true,
              "configOverrides": {}
            }
          ]
        }
      ],
      "outputContracts": [
        {
          "contractId": "coding.patch",
          "name": "Coding Patch Output",
          "schema": {
            "type": "object"
          },
          "validationLevel": "strict"
        }
      ],
      "promptOverrides": {},
      "capabilities": {
        "supportedTaskTypes": ["bugfix", "refactor", "review"],
        "requiredTools": ["repo_map", "patch_apply", "test_runner", "static_analysis", "file_read", "file_write", "shell_exec"],
        "optionalTools": ["git_log", "dependency_graph", "benchmark_runner"],
        "modelPreferences": {
          "primary": "MiniMax-M2.7"
        },
        "budgetLimits": {
          "maxTokensPerTask": 12000,
          "maxCostPerTask": 10
        },
        "securityLevel": "standard"
      },
      "status": "active",
      "externalAdapters": ["github"],
      "pluginBindings": [
        {
          "bindingId": "coding.retriever",
          "domainId": "coding",
          "pluginType": "retriever",
          "pluginId": "plugin.coding.retriever",
          "priority": 10,
          "enabled": true,
          "config": {}
        },
        {
          "bindingId": "coding.presenter",
          "domainId": "coding",
          "pluginType": "presenter",
          "pluginId": "plugin.coding.presenter",
          "priority": 5,
          "enabled": true,
          "config": {}
        },
        {
          "bindingId": "coding.github",
          "domainId": "coding",
          "pluginType": "adapter",
          "pluginId": "plugin.shared.github_adapter",
          "priority": 3,
          "enabled": true,
          "config": {}
        }
      ]
    }
  ]
}
