{
  "domainId": "quant-trading",
  "name": "Quant Trading",
  "description": "Quantitative trading workflows with mandatory pre-trade risk controls.",
  "version": "1.0.0",
  "status": "active",
  "ringId": "ring1",
  "divisionId": "analytics",
  "latencyTier": "ultra_realtime",
  "riskProfile": {
    "defaultRiskLevel": "high",
    "maxAutonomyLevel": "supervised"
  },
  "riskSpec": {
    "advisoryOnly": false,
    "humanAccountable": true,
    "deterministicHotPathOnly": true
  },
  "workflows": [
    {
      "workflowId": "quant-trading.primary",
      "name": "Quant Trading Primary Workflow",
      "triggerConditions": {
        "domainId": "quant-trading"
      },
      "planGraph": {
        "graphId": "graph:quant-trading:primary",
        "nodes": [
          {
            "nodeId": "node:quant-trading:pre-risk-check",
            "nodeType": "tool",
            "inputRefs": ["task:${taskId}"],
            "outputSchemaRef": "schema:quant-trading.pre-risk-check",
            "riskClass": "high",
            "budgetIntent": {
              "amount": 0.05,
              "currency": "USD",
              "resourceKinds": ["token", "api"]
            },
            "sideEffectProfile": {
              "mayCommitExternalEffect": false,
              "reversible": true
            },
            "retryPolicyRef": "retry:quant-trading.default",
            "timeoutMs": 30000
          },
          {
            "nodeId": "node:quant-trading:strategy-backtest",
            "nodeType": "llm",
            "inputRefs": ["node:quant-trading:pre-risk-check.output"],
            "outputSchemaRef": "schema:quant-trading.backtest",
            "riskClass": "high",
            "budgetIntent": {
              "amount": 0.15,
              "currency": "USD",
              "resourceKinds": ["token", "compute"]
            },
            "sideEffectProfile": {
              "mayCommitExternalEffect": false,
              "reversible": true
            },
            "retryPolicyRef": "retry:quant-trading.default",
            "timeoutMs": 120000
          }
        ],
        "edges": [
          {
            "edgeId": "edge:quant-trading:risk-to-backtest",
            "sourceNodeId": "node:quant-trading:pre-risk-check",
            "targetNodeId": "node:quant-trading:strategy-backtest",
            "condition": "always"
          }
        ],
        "entryNodeIds": ["node:quant-trading:pre-risk-check"],
        "terminalNodeIds": ["node:quant-trading:strategy-backtest"],
        "joinStrategy": "all",
        "graphHash": "sha256:quant-trading-primary-v1"
      }
    }
  ],
  "toolBundles": [
    {
      "bundleId": "quant-trading.tools",
      "tools": [
        { "toolName": "market_data", "enabled": true },
        { "toolName": "strategy_backtester", "enabled": true },
        { "toolName": "risk_calculator", "enabled": true },
        { "toolName": "order_execution", "enabled": false }
      ]
    }
  ],
  "outputContracts": [
    {
      "contractId": "quant-trading.pre-trade-risk",
      "name": "Pre Trade Risk Evidence",
      "schema": {
        "required": [
          "max_drawdown",
          "pre_trade_risk",
          "approval_ref"
        ]
      },
      "validationLevel": "strict"
    }
  ],
  "capabilities": {
    "supportedTaskTypes": [
      "strategy_backtest",
      "pre_trade_risk_check"
    ],
    "requiredTools": [
      "market_data",
      "strategy_backtester",
      "risk_calculator"
    ],
    "optionalTools": [
      "order_execution"
    ],
    "modelPreferences": {
      "analysis": "high_reasoning",
      "execution": "deterministic_hot_path"
    },
    "budgetLimits": {
      "maxTokensPerTask": 8000,
      "maxCostPerTask": 25
    },
    "securityLevel": "restricted"
  },
  "workflowProfile": {
    "workflowId": "quant-trading.primary",
    "rollout": "baseline"
  },
  "toolProfile": {
    "requiredTools": [
      "market_data",
      "strategy_backtester",
      "risk_calculator",
      "order_execution"
    ],
    "optionalTools": []
  },
  "evalProfile": {
    "blockingMetrics": [
      "sharpe_ratio",
      "max_drawdown",
      "pre_trade_risk"
    ]
  },
  "ownership": {
    "ownerTeam": "quant-trading-owners",
    "escalationTeam": "quant-trading-escalation"
  }
}
