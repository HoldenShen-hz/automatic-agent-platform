{
  "configVersion": "bundle-derived",
  "configSchemaVersion": "bundle-derived",
  "maxConcurrentTasks": 4,
  "defaultTaskTimeoutMs": 300000,
  "defaultStepTimeoutMs": 120000,
  "apiDefaultTimeoutMs": 5000,
  "apiMaxTimeoutMs": 30000,
  "maxAgentRounds": 16,
  "maxToolCalls": 32,
  "retryMax": 3,
  "circuitBreaker": {
    "enabled": true,
    "threshold": 5,
    "resetMs": 60000,
    "halfOpenMaxAttempts": 1
  },
  "rateLimit": {
    "enabled": true,
    "requestsPerMinute": 120,
    "perTenantRequestsPerMinute": 90,
    "perPrincipalRequestsPerMinute": 60
  },
  "configDriftReconciler": {
    "interval": 300000
  },
  "healthCheckIntervalMs": 30000,
  "shutdownGracePeriodMs": 10000,
  "logLevel": "info",
  "metricsEnabled": true,
  "tracingEnabled": true,
  "retryPolicy": {
    "maxRetries": 3,
    "backoffMs": 1000,
    "maxBackoffMs": 30000
  }
}
