{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "configVersion": "runtime-default-v1",
  "maxConcurrentTasks": 1,
  "defaultTaskTimeoutMs": 300000,
  "apiDefaultTimeoutMs": 5000,
  "apiMaxTimeoutMs": 30000,
  "maxAgentRounds": 6,
  "maxToolCalls": 8,
  "healthCheckIntervalMs": 30000,
  "shutdownGracePeriodMs": 10000,
  "logLevel": "info",
  "metricsEnabled": true,
  "tracingEnabled": false,
  "retryPolicy": {
    "maxRetries": 3,
    "backoffMs": 1000,
    "maxBackoffMs": 30000
  },
  "circuitBreaker": {
    "enabled": true,
    "failureThreshold": 5,
    "resetTimeoutMs": 30000,
    "halfOpenMaxAttempts": 3
  },
  "rateLimit": {
    "enabled": true,
    "maxRequestsPerSecond": 100,
    "burstSize": 200,
    "global": true
  },
  "stateMachine": {
    "type": "RuntimeStateMachine",
    "statusTransitionTimeoutMs": 5000,
    "enableCompensation": true,
    "denyByDefault": true,
    "invariantCheckEnabled": true,
    "nonOverridableInvariants": [
      "INV-STATE-001",
      "INV-RUN-001",
      "INV-GRAPH-001",
      "INV-BUDGET-001",
      "INV-REPLAY-001",
      "INV-SIDEEFFECT-001",
      "INV-POLICY-001"
    ]
  },
  "fivePlane": {
    "interfacePlaneEnabled": true,
    "x1FabricEnabled": true,
    "controlPlaneEnabled": true,
    "orchestrationPlaneEnabled": true,
    "executionPlaneEnabled": true,
    "stateEvidencePlaneEnabled": true,
    "startupOrder": ["P5", "X1", "P2", "P3", "P4", "P1"]
  },
  "harnessRuntime": {
    "maxIterations": 100,
    "maxReplans": 5,
    "maxDurationMs": 600000,
    "hitlTimeoutMs": 300000,
    "entryGuardEnabled": true,
    "planGraphBundleRequired": true
  },
  "budgetConfiguration": {
    "reserveBeforeExecute": true,
    "hardCapEnforcement": true,
    "sweepIntervalMs": 60000,
    "reservationTtlMs": 300000
  },
  "eventRegistry": {
    "namespacePrefix": "platform",
    "tier1Events": [
      "harness_run.created",
      "harness_run.status_changed",
      "node_run.created",
      "node_run.status_changed",
      "budget.reserved",
      "budget.settled",
      "budget.released",
      "side_effect.proposed",
      "side_effect.committed",
      "side_effect.reconciling"
    ],
    "dlqEnabled": true,
    "dlqMaxRetries": 5
  }
}
