{
  "configVersion": "v4.3",
  "configSchemaVersion": "v4.3",
  "maxConcurrentTasks": 4,
  "defaultTaskTimeoutMs": 300000,
  "defaultStepTimeoutMs": 120000,
  "apiDefaultTimeoutMs": 5000,
  "apiMaxTimeoutMs": 30000,
  "maxAgentRounds": 6,
  "maxToolCalls": 8,
  "retryMax": 3,
  "circuitBreaker": {
    "enabled": true,
    "threshold": 5
  },
  "rateLimit": {
    "enabled": true,
    "requestsPerMinute": 120
  },
  "configDriftReconciler": {
    "interval": 300000
  },
  "healthCheckIntervalMs": 30000,
  "shutdownGracePeriodMs": 10000,
  "logLevel": "info",
  "metricsEnabled": true,
  "tracingEnabled": true,
  "retryPolicy": {
    "maxRetries": 3,
    "backoffMs": 1000,
    "maxBackoffMs": 30000
  }
}
